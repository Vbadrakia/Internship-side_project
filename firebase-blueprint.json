{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform, either a candidate or a recruiter.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["candidate", "recruiter"] },
        "company": { "type": "string" },
        "avatar": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "settings": {
          "type": "object",
          "properties": {
            "darkMode": { "type": "boolean" },
            "blindHiring": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Job": {
      "title": "Job",
      "description": "A job posting created by a recruiter.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "salary": { "type": "string" },
        "description": { "type": "string" },
        "requirements": { "type": "array", "items": { "type": "string" } },
        "responsibilities": { "type": "array", "items": { "type": "string" } },
        "postedAt": { "type": "string" },
        "deadline": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "Closed"] }
      },
      "required": ["id", "title", "company", "location", "status"]
    },
    "Application": {
      "title": "Application",
      "description": "A job application submitted by a candidate.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobId": { "type": "string" },
        "candidateId": { "type": "string" },
        "candidateName": { "type": "string" },
        "candidateEmail": { "type": "string" },
        "appliedAt": { "type": "string" },
        "status": { "type": "string" },
        "feedback": { "type": "string" },
        "feedbackRating": { "type": "number" },
        "aiScore": { "type": "number" },
        "aiReason": { "type": "string" },
        "isSharedWithHM": { "type": "boolean" },
        "resumeSummary": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "jobId", "candidateId", "status"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in a chat conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "userId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings."
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Job postings."
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Candidate applications."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat history for AI assistant."
    }
  }
}
